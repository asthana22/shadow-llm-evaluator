# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=INFO

# Primary LLM — DigitalOcean Serverless Inference
# https://inference.do-ai.run/v1/chat/completions
# Use a Model Access Key or DO OAuth token (dop_v1_/doo_v1_) with inference scope.
PRIMARY_LLM_URL=https://inference.do-ai.run/v1/chat/completions
PRIMARY_LLM_API_KEY=your-key-here
PRIMARY_LLM_MODEL=llama3.3-70b-instruct

# Candidate LLM (shadow evaluation — separate key/model from primary)
CANDIDATE_LLM_URL=https://inference.do-ai.run/v1/chat/completions
CANDIDATE_LLM_API_KEY=your-candidate-key-here
CANDIDATE_LLM_MODEL=openai-gpt-oss-120b

# Timeouts (ms)
PRIMARY_TIMEOUT_MS=60000
SHADOW_JOB_TIMEOUT_MS=30000

# Shadow queue — bounded concurrency & load shedding
SHADOW_MAX_CONCURRENCY=50
SHADOW_MAX_QUEUE_SIZE=500

# Redis (queue + live metrics)
REDIS_URL=redis://localhost:6379

# Database — SQLite locally, Postgres in production
DB_DRIVER=sqlite
SQLITE_PATH=./data/shadow_evaluator.db
# DATABASE_URL=postgresql://evaluator:evaluator@localhost:5432/shadow_evaluator
ENABLE_AUDIT_LOG=false
